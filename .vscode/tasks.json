{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: build Debug",
            "command": "cmake",
            "type": "process",
            "args": [
                "--build",
                "${workspaceFolder}\\build",
                "--config",
                "Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build Debug configuration using CMake",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "C/C++: build Release",
            "command": "cmake",
            "type": "process",
            "args": [
                "--build",
                "${workspaceFolder}\\build",
                "--config",
                "Release"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Build Release configuration using CMake",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "CMake: Configure",
            "command": "cmake",
            "type": "process",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}\\build",
                "-G",
                "Visual Studio 17 2022"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Configure CMake with Visual Studio 2022 generator",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "CMake: Clean Rebuild Debug",
            "command": "cmd.exe",
            "type": "process",
            "args": [
                "/c",
                "rmdir",
                "/s",
                "/q",
                "${workspaceFolder}\\build",
                "&&",
                "cmake",
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}\\build",
                "-G",
                "Visual Studio 17 2022",
                "&&",
                "cmake",
                "--build",
                "${workspaceFolder}\\build",
                "--config",
                "Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Clean build directory and rebuild Debug",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}